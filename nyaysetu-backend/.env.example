# --- App / branding (neutral & swappable) ---
APP_NAME=NyaySetu
APP_TAGLINE=Aapka Kanoon, Aapke Haath
APP_ENV=development
LOG_LEVEL=INFO
# Comma-separated origins allowed to call the API from a browser (the frontend).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- LLM (Ollama, local) — the free default engine ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT_S=300

# --- High-power mode (OPTIONAL, off by default) ---
# Switch the answering engine to Claude for higher-quality, more reliable legal answers.
# Leave LLM_PROVIDER=ollama to stay fully free/local. To enable:
#   1) pip install anthropic   2) set LLM_PROVIDER=claude   3) set ANTHROPIC_API_KEY
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
HIGH_POWER_MODEL=claude-opus-4-8
ANTHROPIC_TIMEOUT_S=120

# --- Messaging channels / WhatsApp (Pillar 4, OFF by default) ---
# Reach citizens on WhatsApp with the SAME cited, current-law, trust-framed answers.
# Delivery backend: "console" (local, logs only, nothing sent) or "whatsapp" (live).
# Stays "console" so the path is fully testable locally with nothing leaving the box.
# To go live: deploy with a public HTTPS URL, create a Meta WhatsApp Cloud API app,
# point its webhook at /webhooks/whatsapp, then set the five values below.
MESSAGING_PROVIDER=console
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_URL=https://graph.facebook.com/v21.0

# --- Embeddings (dense retrieval) ---
# InLegalBERT is trained on Indian SC/HC case law — much better than a generic encoder.
EMBEDDING_MODEL=law-ai/InLegalBERT
# Asymmetric prefixes for e5-style multilingual models; leave empty for InLegalBERT.
EMBEDDING_QUERY_PREFIX=
EMBEDDING_PASSAGE_PREFIX=

# --- Reranker (cross-encoder precision pass) ---
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
USE_RERANKER=true

# --- Vector store (Qdrant) ---
# Leave QDRANT_URL empty to run embedded (local file under INDEX_DIR/qdrant).
# Set it (e.g. http://localhost:6333) to use a Qdrant server in production.
QDRANT_URL=
QDRANT_COLLECTION=nyaysetu_chunks

# --- Retrieval tuning ---
FETCH_K=30
RERANK_CANDIDATES=50
TOP_K=6
RRF_K=60
# Below this top rerank score the engine abstains instead of risking a wrong section.
# 0.0 = abstain when even the best-matched law scores net-irrelevant (negative logit).
# Calibrated on real queries: legal Qs score +2.7..+9.4, off-topic -11.1..-1.6.
MIN_RERANK_SCORE=0.0

# --- Data + index locations ---
CORPUS_DIR=data/corpus
IPC_DIR=data/ipc
BNS_DIR=data/bns
QA_DIR=data/indiclegalqa
INDEX_DIR=models/index

# --- Chunking (guides only; statutes/QA are atomic) ---
CHUNK_SIZE=700
CHUNK_OVERLAP=100

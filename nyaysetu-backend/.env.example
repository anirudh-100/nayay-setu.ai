# --- App / branding (neutral & swappable) ---
APP_NAME=NyaySetu
APP_TAGLINE=Aapka Kanoon, Aapke Haath
APP_ENV=development
LOG_LEVEL=INFO
# Comma-separated origins allowed to call the API from a browser (the frontend).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- LLM (Ollama, local) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT_S=300

# --- Embeddings (dense retrieval) ---
# InLegalBERT is trained on Indian SC/HC case law — much better than a generic encoder.
EMBEDDING_MODEL=law-ai/InLegalBERT
# Asymmetric prefixes for e5-style multilingual models; leave empty for InLegalBERT.
EMBEDDING_QUERY_PREFIX=
EMBEDDING_PASSAGE_PREFIX=

# --- Reranker (cross-encoder precision pass) ---
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
USE_RERANKER=true

# --- Vector store (Qdrant) ---
# Leave QDRANT_URL empty to run embedded (local file under INDEX_DIR/qdrant).
# Set it (e.g. http://localhost:6333) to use a Qdrant server in production.
QDRANT_URL=
QDRANT_COLLECTION=nyaysetu_chunks

# --- Retrieval tuning ---
FETCH_K=30
RERANK_CANDIDATES=50
TOP_K=6
RRF_K=60
# Below this top rerank score the engine abstains instead of risking a wrong section.
MIN_RERANK_SCORE=-10.0

# --- Data + index locations ---
CORPUS_DIR=data/corpus
IPC_DIR=data/ipc
BNS_DIR=data/bns
QA_DIR=data/indiclegalqa
INDEX_DIR=models/index

# --- Chunking (guides only; statutes/QA are atomic) ---
CHUNK_SIZE=700
CHUNK_OVERLAP=100
